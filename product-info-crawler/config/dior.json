{
  "brand": {
    "id": "dior",
    "display_name": "Dior",
    "scraper": "dior"
  },
  "google_sheets": {
    "service_account_file": "credentials/service_account.json",
    "spreadsheet_name": "디올 상품 리스트"
  },
  "scraping_settings": {
    "headless": false,
    "scroll_pause_time": 3.0,
    "max_products_per_category": 1000,
    "max_scroll_loops": 20,
    "max_placeholder_retries": 3,
    "initial_wait_sec": 15,
    "inter_category_delay_sec": 5,
    "fetch_detail": true,
    "detail_page_delay_sec": 5,
    "detail_checkpoint_interval": 5,
    "download_images": true,
    "process_images": true,
    "popup_selectors": [
      "#onetrust-accept-btn-handler",
      "button[aria-label='Close']",
      "button[aria-label='close']",
      "button[class*='close']"
    ],
    "popup_xpaths": [
      "//button[contains(., '동의')]",
      "//button[contains(., 'Accept')]",
      "//button[contains(., '닫기')]"
    ]
  },
  "selectors": {
    "product_card": "div.lazyload-wrapper .DS-Card",
    "lazy_placeholder": "div.lazyload-wrapper .lazyload-placeholder",
    "name": "h2, h3, [data-testid*='product-name']",
    "price": "[content][itemprop='price'], [data-testid*='price'], span[class*='price']",
    "link": "a[href]"
  },
  "detail_selectors": {
    "description": ".product-description__text, [data-testid='product-description']",
    "sizes": ".size-selector__option, [data-testid*='size-option']",
    "images": ".DS-Product-Slideshow img[src], .product-images__image img[src]"
  },
  "categories": {
    "Wallet(Man)": "https://www.dior.com/ko_kr/fashion/mens-fashion/small-leather-goods/compact-wallets",
    "Ring(Woman)": "https://www.dior.com/ko_kr/fashion/여성-패션/패션주얼리/반지"
  }
}
